{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/api/index.py" },
    { "source": "/_/backend/(.*)", "destination": "backend/api/index.py" },
    { "source": "/(.*)", "destination": "frontend/$1" }
  ]
}