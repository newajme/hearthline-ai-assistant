# ─── DATABASE SETTINGS ──────────────────────────────────────────
POSTGRES_DB=hearthline
POSTGRES_USER=hearthline
POSTGRES_PASSWORD=hearthline_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://hearthline:hearthline_dev@db:5432/hearthline

# ─── BACKEND (THE BRAIN) ────────────────────────────────────────
DJANGO_SECRET_KEY=local-development-only-key
DJANGO_DEBUG=1
# This line tells the app it is allowed to talk to your Cloudflare bridge.
# We add .cloudshell.dev to ensure the Google Cloud Web Preview works.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,bulk-decreased-implies-unto.trycloudflare.com,.cloudshell.dev

# ─── FRONTEND (THE FACE) ────────────────────────────────────────
# This allows your Vercel site to talk to this Cloud Shell machine
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://bulk-decreased-implies-unto.trycloudflare.com

# ─── CONNECTIONS ────────────────────────────────────────────────
INTERNAL_API_URL=http://backend:8000/api
NEXT_PUBLIC_API_URL=https://bulk-decreased-implies-unto.trycloudflare.com/api
